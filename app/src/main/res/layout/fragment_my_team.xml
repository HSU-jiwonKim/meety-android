<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D14">

    <!-- 헤더 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="내 모임"
            android:textColor="#F0F0F5"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="+ 모임 만들기"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="#4F8EF7" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 내 모임 카드 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#16161F"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <!-- 상단 배지 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="팀장"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:background="#7C5CFC"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="모집중"
                        android:textColor="#2ECC8A"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:background="#0D2A1A" />

                    <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="스터디"
                        android:textColor="#8888A8"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📚 토익 900 목표반"
                    android:textColor="#F0F0F5"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="매일 저녁 9시 온라인 스터디. 목표 달성까지 함께 달려요!"
                    android:textColor="#8888A8"
                    android:textSize="13sp"
                    android:layout_marginBottom="16dp" />

                <!-- 멤버 아바타 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView android:layout_width="36dp" android:layout_height="36dp" android:text="김" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" android:gravity="center" android:background="@drawable/circle_blue" />
                    <TextView android:layout_width="36dp" android:layout_height="36dp" android:text="이" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" android:gravity="center" android:background="@drawable/circle_purple" android:layout_marginStart="-6dp" />
                    <TextView android:layout_width="36dp" android:layout_height="36dp" android:text="박" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" android:gravity="center" android:background="@drawable/circle_green" android:layout_marginStart="-6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  3/4명"
                        android:textColor="#8888A8"
                        android:textSize="13sp" />

                    <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1자리 남음"
                        android:textColor="#FF6B6B"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- 버튼들 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="멤버 관리"
                        android:textColor="#8888A8"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="#1E1E2A"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="💬 채팅"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="#4F8EF7" />
                </LinearLayout>
            </LinearLayout>

            <!-- 참가 신청 받은 카드 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#16161F"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="멤버" android:textColor="#FFFFFF" android:textSize="11sp" android:textStyle="bold" android:paddingStart="10dp" android:paddingEnd="10dp" android:paddingTop="3dp" android:paddingBottom="3dp" android:background="#4F8EF7" android:layout_marginEnd="8dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="활동중" android:textColor="#4F8EF7" android:textSize="11sp" android:textStyle="bold" android:paddingStart="10dp" android:paddingEnd="10dp" android:paddingTop="3dp" android:paddingBottom="3dp" android:background="#0D1A2A" />
                    <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="운동" android:textColor="#8888A8" android:textSize="12sp" />
                </LinearLayout>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="🏃 새벽 러닝 크루" android:textColor="#F0F0F5" android:textSize="18sp" android:textStyle="bold" android:layout_marginBottom="8dp" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="매주 화/목 새벽 6시 한강공원 집합!" android:textColor="#8888A8" android:textSize="13sp" android:layout_marginBottom="16dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="모임 정보" android:textColor="#8888A8" android:textSize="14sp" android:textStyle="bold" android:gravity="center" android:background="#1E1E2A" android:layout_marginEnd="10dp" />
                    <TextView android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="💬 채팅" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" android:gravity="center" android:background="#4F8EF7" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>