<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D14">

    <!-- 헤더 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="채팅"
            android:textColor="#F0F0F5"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- 채팅방 목록 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 채팅방 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="76dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:background="#0D0D14">

                <!-- 아바타 -->
                <RelativeLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_marginEnd="14dp">

                    <TextView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:text="📚"
                        android:textSize="22sp"
                        android:gravity="center"
                        android:background="@drawable/circle_blue" />

                    <TextView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:text="3"
                        android:textColor="#FFFFFF"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/circle_red"
                        android:layout_alignParentTop="true"
                        android:layout_alignParentEnd="true" />
                </RelativeLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="토익 900 목표반"
                            android:textColor="#F0F0F5"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="오후 11:42"
                            android:textColor="#444460"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="김지원: 오늘 스터디 9시에 시작해요~"
                        android:textColor="#8888A8"
                        android:textSize="13sp"
                        android:maxLines="1"
                        android:ellipsize="end" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#16161F" android:layout_marginStart="20dp" />

            <!-- 채팅방 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="76dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:background="#0D0D14">

                <TextView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:text="🏃"
                    android:textSize="22sp"
                    android:gravity="center"
                    android:background="@drawable/circle_green"
                    android:layout_marginEnd="14dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="새벽 러닝 크루" android:textColor="#F0F0F5" android:textSize="15sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="어제" android:textColor="#444460" android:textSize="11sp" />
                    </LinearLayout>

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="이수연: 내일 6시 한강 출발입니다!" android:textColor="#8888A8" android:textSize="13sp" android:maxLines="1" android:ellipsize="end" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#16161F" android:layout_marginStart="20dp" />

            <!-- 채팅방 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="76dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:background="#0D0D14">

                <TextView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:text="💻"
                    android:textSize="22sp"
                    android:gravity="center"
                    android:background="@drawable/circle_purple"
                    android:layout_marginEnd="14dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="앱개발 프로젝트팀" android:textColor="#F0F0F5" android:textSize="15sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="월요일" android:textColor="#444460" android:textSize="11sp" />
                    </LinearLayout>

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="박민준: 다음 회의 일정 잡아요" android:textColor="#8888A8" android:textSize="13sp" android:maxLines="1" android:ellipsize="end" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#16161F" android:layout_marginStart="20dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>