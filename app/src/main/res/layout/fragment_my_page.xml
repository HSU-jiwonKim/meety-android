<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D14">

    <!-- 헤더 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="MY"
            android:textColor="#F0F0F5"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="✏️"
            android:textSize="18sp"
            android:gravity="center"
            android:background="#1E1E2A" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 프로필 카드 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#16161F"
                android:padding="24dp"
                android:gravity="center"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:text="김"
                    android:textColor="#FFFFFF"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/circle_blue"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="김지원"
                    android:textColor="#F0F0F5"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="한성대학교 · 컴퓨터공학과"
                    android:textColor="#8888A8"
                    android:textSize="13sp"
                    android:layout_marginBottom="12dp" />

                <!-- 태그들 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="INTJ" android:textColor="#4F8EF7" android:textSize="12sp" android:textStyle="bold" android:paddingStart="10dp" android:paddingEnd="10dp" android:paddingTop="4dp" android:paddingBottom="4dp" android:background="#0D1A2A" android:layout_marginEnd="6dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="#스터디" android:textColor="#8888A8" android:textSize="12sp" android:paddingStart="10dp" android:paddingEnd="10dp" android:paddingTop="4dp" android:paddingBottom="4dp" android:background="#1E1E2A" android:layout_marginEnd="6dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="#개발" android:textColor="#8888A8" android:textSize="12sp" android:paddingStart="10dp" android:paddingEnd="10dp" android:paddingTop="4dp" android:paddingBottom="4dp" android:background="#1E1E2A" />
                </LinearLayout>

                <!-- 인증 배지 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✅ 학생증 인증 완료"
                    android:textColor="#2ECC8A"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:background="#0D2A1A" />
            </LinearLayout>

            <!-- 활동 통계 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#16161F"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2" android:textColor="#4F8EF7" android:textSize="24sp" android:textStyle="bold" android:gravity="center" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="참가 모임" android:textColor="#8888A8" android:textSize="12sp" android:gravity="center" />
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="40dp" android:background="#2A2A3A" />

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1" android:textColor="#7C5CFC" android:textSize="24sp" android:textStyle="bold" android:gravity="center" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="만든 모임" android:textColor="#8888A8" android:textSize="12sp" android:gravity="center" />
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="40dp" android:background="#2A2A3A" />

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="12" android:textColor="#2ECC8A" android:textSize="24sp" android:textStyle="bold" android:gravity="center" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="활동 횟수" android:textColor="#8888A8" android:textSize="12sp" android:gravity="center" />
                </LinearLayout>
            </LinearLayout>

            <!-- 메뉴 목록 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#16161F"
                android:layout_marginBottom="16dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="54dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="20dp" android:paddingEnd="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="👤" android:textSize="18sp" android:layout_marginEnd="14dp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="프로필 편집" android:textColor="#F0F0F5" android:textSize="15sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textColor="#444460" android:textSize="20sp" />
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1E1E2A" android:layout_marginStart="52dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="54dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="20dp" android:paddingEnd="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔔" android:textSize="18sp" android:layout_marginEnd="14dp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="알림 설정" android:textColor="#F0F0F5" android:textSize="15sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textColor="#444460" android:textSize="20sp" />
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1E1E2A" android:layout_marginStart="52dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="54dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="20dp" android:paddingEnd="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🎓" android:textSize="18sp" android:layout_marginEnd="14dp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="학생증 인증" android:textColor="#F0F0F5" android:textSize="15sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textColor="#444460" android:textSize="20sp" />
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1E1E2A" android:layout_marginStart="52dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="54dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="20dp" android:paddingEnd="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🚪" android:textSize="18sp" android:layout_marginEnd="14dp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="로그아웃" android:textColor="#FF6B6B" android:textSize="15sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textColor="#444460" android:textSize="20sp" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>