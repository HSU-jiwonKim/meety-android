<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D14">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:gravity="center_vertical"
        android:background="#0D0D14">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="오늘의 모임 🔍"
            android:textColor="#F0F0F5"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="🔔"
            android:textSize="18sp"
            android:gravity="center"
            android:background="#1E1E2A"
            android:layout_marginEnd="8dp" />

        <TextView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="⚙️"
            android:textSize="18sp"
            android:gravity="center"
            android:background="#1E1E2A" />
    </LinearLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:gravity="center_vertical">

            <TextView android:layout_width="wrap_content" android:layout_height="32dp" android:text="전체" android:textColor="#FFFFFF" android:textSize="13sp" android:gravity="center" android:paddingStart="16dp" android:paddingEnd="16dp" android:background="#4F8EF7" android:layout_marginEnd="8dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="32dp" android:text="스터디" android:textColor="#8888A8" android:textSize="13sp" android:gravity="center" android:paddingStart="16dp" android:paddingEnd="16dp" android:background="#16161F" android:layout_marginEnd="8dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="32dp" android:text="운동" android:textColor="#8888A8" android:textSize="13sp" android:gravity="center" android:paddingStart="16dp" android:paddingEnd="16dp" android:background="#16161F" android:layout_marginEnd="8dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="32dp" android:text="취미" android:textColor="#8888A8" android:textSize="13sp" android:gravity="center" android:paddingStart="16dp" android:paddingEnd="16dp" android:background="#16161F" android:layout_marginEnd="8dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="32dp" android:text="프로젝트" android:textColor="#8888A8" android:textSize="13sp" android:gravity="center" android:paddingStart="16dp" android:paddingEnd="16dp" android:background="#16161F" android:layout_marginEnd="8dp" />
        </LinearLayout>
    </HorizontalScrollView>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 카드 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#16161F"
                android:layout_marginBottom="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:background="#0a0f1a">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:text="김"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:background="@drawable/circle_blue" />

                        <TextView
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:text="이"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:background="@drawable/circle_purple"
                            android:layout_marginStart="-8dp" />

                        <TextView
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:text="+"
                            android:textColor="#8888A8"
                            android:textSize="20sp"
                            android:gravity="center"
                            android:background="@drawable/circle_gray"
                            android:layout_marginStart="-8dp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentTop="true"
                        android:layout_alignParentStart="true"
                        android:layout_margin="10dp"
                        android:text="한성대학교"
                        android:textColor="#8888A8"
                        android:textSize="11sp"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:background="#CC0D0D14" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentTop="true"
                        android:layout_alignParentEnd="true"
                        android:layout_margin="10dp"
                        android:text="스터디"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:background="#4F8EF7" />
                </RelativeLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="📚 토익 900 목표반"
                            android:textColor="#F0F0F5"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="4명 모집"
                            android:textColor="#8888A8"
                            android:textSize="12sp"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="3dp"
                            android:paddingBottom="3dp"
                            android:background="#1E1E2A" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="#토익" android:textColor="#8888A8" android:textSize="12sp" android:paddingStart="10dp" android:paddingEnd="10dp" android:paddingTop="3dp" android:paddingBottom="3dp" android:background="#1E1E2A" android:layout_marginEnd="6dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="#매일스터디" android:textColor="#8888A8" android:textSize="12sp" android:paddingStart="10dp" android:paddingEnd="10dp" android:paddingTop="3dp" android:paddingBottom="3dp" android:background="#1E1E2A" android:layout_marginEnd="6dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="#목표지향" android:textColor="#8888A8" android:textSize="12sp" android:paddingStart="10dp" android:paddingEnd="10dp" android:paddingTop="3dp" android:paddingBottom="3dp" android:background="#1E1E2A" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🎓 경영 · 영문 · 컴공 외"
                        android:textColor="#8888A8"
                        android:textSize="13sp"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:text="넘기기"
                            android:textColor="#8888A8"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:background="#1E1E2A"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="2"
                            android:text="🙋 참가 신청"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:background="#4F8EF7" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- 카드 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#16161F"
                android:layout_marginBottom="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:background="#0a1a0f">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:text="최"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:background="@drawable/circle_green" />

                        <TextView
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:text="정"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:background="@drawable/circle_blue"
                            android:layout_marginStart="-8dp" />

                        <TextView
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:text="+"
                            android:textColor="#8888A8"
                            android:textSize="20sp"
                            android:gravity="center"
                            android:background="@drawable/circle_gray"
                            android:layout_marginStart="-8dp" />
                    </LinearLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentTop="true" android:layout_alignParentStart="true" android:layout_margin="10dp" android:text="국민대학교" android:textColor="#8888A8" android:textSize="11sp" android:paddingStart="10dp" android:paddingEnd="10dp" android:paddingTop="3dp" android:paddingBottom="3dp" android:background="#CC0D0D14" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentTop="true" android:layout_alignParentEnd="true" android:layout_margin="10dp" android:text="운동" android:textColor="#FFFFFF" android:textSize="11sp" android:textStyle="bold" android:paddingStart="10dp" android:paddingEnd="10dp" android:paddingTop="3dp" android:paddingBottom="3dp" android:background="#2ECC8A" />
                </RelativeLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="🏃 새벽 러닝 크루" android:textColor="#F0F0F5" android:textSize="16sp" android:textStyle="bold" android:layout_marginBottom="8dp" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="🎓 체육 · 간호 · 기계공학 외" android:textColor="#8888A8" android:textSize="13sp" android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="넘기기" android:textColor="#8888A8" android:textSize="14sp" android:textStyle="bold" android:gravity="center" android:background="#1E1E2A" android:layout_marginEnd="10dp" />
                        <TextView android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="2" android:text="🙋 참가 신청" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" android:gravity="center" android:background="#4F8EF7" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>